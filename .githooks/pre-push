#!/usr/bin/env sh
set -eu

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File scripts/check-public-sensitive.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -File scripts/check-public-sensitive.ps1
else
  echo "推送已停止：找不到 PowerShell，无法执行公开敏感信息扫描。" >&2
  exit 1
fi
