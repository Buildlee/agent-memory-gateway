# 这里只列出变量名和安全的占位值，不含密码或密钥。
# 实际环境文件请放在受保护的本机位置，不要提交到 Git。
MEMORY_GATEWAY_SECRETS_FILE=/secure/path/memory-gateway/metadata.env
MEMORY_GATEWAY_BACKEND_NETWORK=memory-backend
MEMORY_GATEWAY_PUBLIC_NAME=memory-gateway.example.internal
MEMORY_GATEWAY_BIND_ADDRESS=127.0.0.1
MEMORY_GATEWAY_HTTPS_PORT=8443
MEMORY_WORKER_HEARTBEAT_MAX_SECONDS=30
# 默认 slim 模式还会从宿主机受保护的 admin.env 读取以下公开定位信息。
MEMORY_ADMIN_AGENT_INSTALLATION_ID=central-admin-agent
MEMORY_ADMIN_DEVICE_ID=central-memory-host
MEMORY_DEFAULT_WORKSPACE=workspace-id
MEMORY_ADMIN_PUBLIC_BASE_URL=https://memory-gateway.example.internal:8443/admin/
MEMORY_ADMIN_SIDECAR_STATE_DIR=/secure/path/memory-gateway/admin-sidecar
MEMORY_ADMIN_CONSOLE_STATE_DIR=/secure/path/memory-gateway/admin-console
# 中枢管理页在单独的受保护环境文件中配置。不要把设备凭据或一次性链接写入此文件。
# 参见 scripts/setup-central-admin.ps1 与 docs/central-admin.md。
