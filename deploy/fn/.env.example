# 这里只列出变量名和安全的占位值，不含密码或密钥。
# 实际环境文件请放在受保护的本机位置，不要提交到 Git。
MEMORY_GATEWAY_SECRETS_FILE=/secure/path/memory-gateway/metadata.env
MEMORY_GATEWAY_BACKEND_NETWORK=memory-backend
MEMORY_GATEWAY_PUBLIC_NAME=memory-gateway.example.internal
MEMORY_GATEWAY_BIND_ADDRESS=127.0.0.1
MEMORY_GATEWAY_HTTPS_PORT=8443
MEMORY_WORKER_HEARTBEAT_MAX_SECONDS=30
