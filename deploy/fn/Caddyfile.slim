{
  admin off
  auto_https disable_redirects
  default_sni {$MEMORY_GATEWAY_PUBLIC_NAME}
  skip_install_trust
}

https://{$MEMORY_GATEWAY_PUBLIC_NAME}:8443 {
  tls internal
  @admin_console path /admin /admin/*
  handle @admin_console {
    reverse_proxy app:8767
  }
  handle {
    reverse_proxy app:8787
  }
}
